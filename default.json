{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "timezone": "Europe/Berlin",
  "extends": ["config:recommended", ":automergeDigest", ":automergeMinor", ":automergeRequireAllStatusChecks"],
  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "matchDepTypes": ["indirect"],
      "matchUpdateTypes": ["!major"],
      "enabled": true
    }
  ],
  "postUpdateOptions": ["gomodUpdateImportPaths", "gomodTidy", "pnpmDedupe", "npmDedupe"],
  "dependencyDashboardLabels": ["dependency-update"],
  "labels": ["dependency-update"]
}
